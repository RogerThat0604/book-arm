import time
from pymycobot import MyCobot280
PORT = "/dev/ttyJETCOBOT"
BAUD = 1000000
mc = MyCobot280(PORT, BAUD)
time.sleep(1)
print("현재 각도:", mc.get_angles())
print("각 관절을 +2도씩 테스트합니다.")
print("위험하면 Ctrl+C")
for joint_index in range(6):
    angles = mc.get_angles()
    print(f"\n[J{joint_index + 1}] 현재 각도:", angles)
    target = angles.copy()
    target[joint_index] += 2.0
    print(f"J{joint_index + 1} +2도 이동")
    mc.send_angles(target, 10)
    time.sleep(1.2)
    print("원위치")
    mc.send_angles(angles, 10)
    time.sleep(1.2)
print("테스트 완료")
# 현재 좌표 확인 current_coords = mc.get_coords() print("현재 좌표:", current_coords) # 1. 먼저 Z축을 낮추기 work_coords = current_coords.copy() work_coords[2] -= 50 # Z를 50mm 내리기 print(f"Z축을 {work_coords[2]}로 내립니다.") mc.send_coords(work_coords, 30, 0) time.sleep(2)
