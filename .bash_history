cat > /home/jetcobot/view_arm_camera.py <<'EOF'
import cv2

cap = cv2.VideoCapture(4)

while True:
    ret, frame = cap.read()
    if not ret:
        print("프레임 실패")
        break

    h, w, _ = frame.shape

    cv2.line(frame, (w//2, 0), (w//2, h), (0, 255, 0), 2)
    cv2.line(frame, (0, h//2), (w, h//2), (0, 255, 0), 2)

    cv2.imshow("Arm Camera", frame)

    if cv2.waitKey(1) & 0xFF == ord("q"):
        break

cap.release()
cv2.destroyAllWindows()
EOF

